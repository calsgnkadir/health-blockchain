# VIP Health Vault — Environment Variables Configuration Template
# Copy this file to '.env' and populate values for your deployment.

ENVIRONMENT=development
VHV_DEMO_MODE=true

# Database Configuration (Optional: Defaults to local SQLite)
# VHV_DATABASE_URL=postgresql://user:password@localhost:5432/vault_db

# Blockchain Connection (Optional: Runs in Simulation Mode if empty)
# VHV_RPC_URL=https://polygon-mumbai.g.alchemy.com/v2/your-api-key
# VHV_PRIVATE_KEY=your-private-key-hex
# VHV_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# IPFS Configuration (Optional: Runs in Local Simulation Mode if empty)
# VHV_IPFS_API_URL=http://localhost:5001
